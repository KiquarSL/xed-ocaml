{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "folding": {
    "offSide": false
  },
  "indentationRules": {
    "decreaseIndentPattern": {
      "pattern": "^\\s*$|^\\s*\\]"
    },
    "increaseIndentPattern": {
      "pattern": "^(depends|depopts|conflicts|build|install|remove|pin-depends|tags|maintainer|authors|x-maintenance-intent)\\s*:\\s*\\["
    }
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*#",
      "action": {
        "indent": "none",
        "appendText": "# "
      }
    },
    {
      "beforeText": "^(depends|build|install|tags)\\s*:\\s*\\[\\s*$",
      "action": {
        "indent": "increase"
      }
    }
  ]
}
